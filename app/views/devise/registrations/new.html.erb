<div class="auth-page">
  <%= image_tag "Ludex.png", class: "auth-logo mb-5", alt: "Ludex", style: "width: 160px;" %>

  <div class="auth-card">
    <h2>Créer un compte</h2>

    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { multipart: true }) do |f| %>
      <%= f.error_notification %>

      <div class="form-inputs">
        <%= f.input :username,
                    required: true,
                    autofocus: true,
                    input_html: { autocomplete: "username" },
                    label: "Nom d'utilisateur" %>
        <%= f.input :email,
                    required: true,
                    autofocus: true,
                    input_html: { autocomplete: "email" },
                    label: "Email" %>
        <%= f.input :password,
                    required: true,
                    hint: ("#{@minimum_password_length} caractères minimum" if @minimum_password_length),
                    input_html: { autocomplete: "new-password" },
                    label: "Mot de passe" %>
        <%= f.input :password_confirmation,
                    required: true,
                    input_html: { autocomplete: "new-password" },
                    label: "Confirmation du mot de passe" %>
        <div class="field-group" style="text-align: center;">
          <%= f.file_field :profile_photo, class: "d-none", accept: "image/*", id: "signup-photo-upload"%>
            <label for="signup-photo-upload" class="btn-upload-photo">
                  <i class="fas fa-camera me-2"></i>Choisir une photo
                </label>
              <br>
            <span id="signup-photo-name" class="upload-filename">Aucun fichier choisi</span>
        </div>
      </div>

      <div class="form-actions">
        <%= f.button :submit, "S'inscrire", class: "btn btn-ludex" %>
      </div>
    <% end %>

    <div class="text-center mt-3">
      <%= render "devise/shared/links" %>
    </div>
  </div>
  <script>
    document.getElementById("signup-photo-upload").addEventListener("change", function() {
      const filename = this.files[0] ? this.files[0].name : "Aucun fichier choisi";
      document.getElementById("signup-photo-name").textContent = filename;
    });
  </script>
</div>
