<div class="auth-page">
  <%= image_tag "Ludex.png", class: "auth-logo mb-5", alt: "Ludex", style: "width: 160px;" %>

  <div class="auth-card">
    <h2>Créer un compte</h2>

    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { multipart: true }) do |f| %>
      <%= f.error_notification %>

      <div class="form-inputs">
        <%= f.input :email,
                    required: true,
                    autofocus: true,
                    input_html: { autocomplete: "email" },
                    label: "Email" %>
        <%= f.input :password,
                    required: true,
                    hint: ("#{@minimum_password_length} caractères minimum" if @minimum_password_length),
                    input_html: { autocomplete: "new-password" },
                    label: "Mot de passe" %>
        <%= f.input :password_confirmation,
                    required: true,
                    input_html: { autocomplete: "new-password" },
                    label: "Confirmation du mot de passe" %>
        <%= f.input :profile_photo,
                    as: :file,
                    required: false,
                    label: "Photo de profil (optionnel)" %>
      </div>

      <div class="form-actions">
        <%= f.button :submit, "S'inscrire", class: "btn btn-ludex" %>
      </div>
    <% end %>

    <div class="text-center mt-3">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
