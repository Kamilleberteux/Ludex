<div class="auth-page">
  <%= image_tag "Ludex.png", class: "auth-logo mb-5", alt: "Ludex", style: "width: 160px;" %>

  <div class="auth-card">
    <h2>Connexion</h2>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="form-inputs">
        <%= f.input :email,
                    required: false,
                    autofocus: true,
                    input_html: { autocomplete: "email", class: "form-control mb-2" },
                    label: "Email" %>
        <%= f.input :password,
                    required: false,
                    input_html: { autocomplete: "current-password", class: "form-control mb-2" },
                    label: "Mot de passe" %>
        <%= f.input :remember_me, as: :boolean, label: "Se souvenir de moi" if devise_mapping.rememberable? %>
      </div>

      <div class="form-actions mt-3">
        <%= f.button :submit, "Se connecter", class: "btn btn-ludex" %>
      </div>
    <% end %>

    <div class="text-center mt-3">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
