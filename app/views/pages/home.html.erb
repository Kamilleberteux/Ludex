<div class="home">
  <!-- Header -->
  <header class="home__header">
    <span class="home__header-logo"><%= image_tag "Lu.png" %></span>
    <%= link_to user_path(current_user), class: "home__header-user" do %>
      <i class="fa-regular fa-user"></i>
    <% end %>
  </header>

  <!-- Greeting -->
  <div class="home__greeting">
    <p class="home__greeting-sub">Good evening,</p>
    <h1 class="home__greeting-name">
      <%= user_signed_in? ? current_user.email.split("@").first.capitalize : "Alex" %> 👋
    </h1>
  </div>

  <!-- FOR YOU card -->
  <div class="home__for-you">
    <div class="home__for-you-card">
      <span class="home__for-you-badge">✦ FOR YOU</span>
      <h2 class="home__for-you-title">Discover your<br>next favourite game</h2>
      <button class="home__for-you-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="me-1">
          <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.099zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
        </svg>
        Get a recommendation
      </button>
      <div class="home__for-you-dice">🎲</div>
    </div>
  </div>

  <!-- My collections -->
  <% if user_signed_in? && @collections.any? %>
  <section class="home__section">
    <div class="home__section-header">
      <h2 class="home__section-title">My collections</h2>
      <%= link_to "See all →", collections_path, class: "home__section-link" %>
    </div>
    <div class="home__collections">
      <% collection_icons = { "Déjà joué" => "✅", "Mes jeux" => "🏠", "Wishlist" => "⭐" } %>
      <% collection_labels = { "Déjà joué" => "Played", "Mes jeux" => "Owned", "Wishlist" => "Wishlist" } %>
      <% @collections.each do |collection| %>
        <%= link_to collection_path(collection), class: "home__collection-card" do %>
          <span class="home__collection-icon"><%= collection_icons[collection.name] || "📦" %></span>
          <span class="home__collection-label"><%= collection_labels[collection.name] || collection.name %></span>
          <span class="home__collection-count"><%= collection.games.count %></span>
        <% end %>
      <% end %>
    </div>
  </section>
  <% end %>

  <!-- Bars near Paris -->
  <section class="home__section">
    <div class="home__section-header">
      <h2 class="home__section-title">Bars near Paris</h2>
      <a href="#" class="home__section-link">See map →</a>
    </div>
    <div class="home__bars">
      <a href="#" class="home__bar-item">
        <div class="home__bar-icon home__bar-icon--green">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 16 16">
            <path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5L14 4.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5h-2z"/>
          </svg>
        </div>
        <div class="home__bar-info">
          <span class="home__bar-name">Le Dé à Jouer</span>
          <span class="home__bar-sub">Bastille · 200+ games</span>
        </div>
        <span class="home__bar-distance">0.4km</span>
      </a>
      <a href="#" class="home__bar-item">
        <div class="home__bar-icon home__bar-icon--purple">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 16 16">
            <path d="M11.5 6.027a.5.5 0 1 1-1 0 .5.5 0 0 1 1 0zm-1.5 1.5a.5.5 0 1 0 0-1 .5.5 0 0 0 0 1zm2.5-.5a.5.5 0 1 1-1 0 .5.5 0 0 1 1 0zm-1.5 1.5a.5.5 0 1 0 0-1 .5.5 0 0 0 0 1zm-6.5-3h1v1h1v1h-1v1h-1v-1h-1v-1h1v-1zM11.5 13H1.5a.5.5 0 0 1-.5-.5v-8A.5.5 0 0 1 1 4h1V2a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v8.5a.5.5 0 0 1-.5.5h-1v1a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1v-1H1.5zm0-1H13V2H3v1h8.5a.5.5 0 0 1 .5.5V12z"/>
          </svg>
        </div>
        <div class="home__bar-info">
          <span class="home__bar-name">Café des Jeux</span>
          <span class="home__bar-sub">Marais · 150+ games</span>
        </div>
        <span class="home__bar-distance">1.1km</span>
      </a>
    </div>
  </section>
</div>
