<div class="home">
  <div class="home__green-area">
  <!-- Header -->
  <header class="home__header">
    <span class="home__header-logo"><%= image_tag "Lu.png" %></span>
    <%= link_to user_path(current_user), class: "home__header-profil" do %>
      <% if current_user.profile_photo_url.present? %>
        <%= image_tag current_user.profile_photo_url, class: "home__header-avatar" %>
      <% else %>
        <i class="fa-regular fa-user"></i>
      <% end %>
    <% end %>

  </header>

  <!-- Greeting -->
  <div class="home__greeting">
    <p class="home__greeting-sub">
      <% if Time.now.hour > 17 %>
        <%= "Bonsoir," %>
      <% elsif Time.now.hour < 12 %>
        <%= "Bon matin," %>
      <% elsif Time.now.hour < 17 %>
        <%= "Bonne aprés-midi," %>
      <% end %>
     </p>
    <h1 class="home__greeting-name">
      <%= user_signed_in? && !current_user.username.nil? ? current_user.username.capitalize : "Alex" %> 👋
    </h1>
  </div>

  <!-- FOR YOU card -->
  <div class="home__for-you">
    <div class="home__for-you-card">
      <span class="home__for-you-badge">✦ POUR TOI</span>
      <h2 class="home__for-you-title">Découvre ton<br>prochain jeu favori!</h2>
      <%= link_to recommendation_form_games_path, class: "home__for-you-btn" do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="me-1">
          <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.099zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
        </svg>
        Recommander un jeu
      <% end %>
      <div class="home__for-you-dice">
        🎲
      </div>
    </div>
  </div>
  </div><!-- /.home__green-area -->

  <!-- My collections -->
  <% if user_signed_in? && @collections.any? %>
  <section class="home__section">
    <div class="home__section-header">
      <h2 class="home__section-title">Mes collections</h2>
    </div>
    <div class="home__collections">
      <% collection_icons = { "Déjà joué" => "👍🏼", "Mes jeux" => "🏡", "Wishlist" => "🎁" } %>
      <% collection_labels = { "Déjà joué" => "Déjà joué", "Mes jeux" => "Mes jeux", "Wishlist" => "Wishlist" } %>
      <% @collections.each do |collection| %>
        <%= link_to collection_path(collection), class: "home__collection-card" do %>
          <span class="home__collection-icon"><%= collection_icons[collection.name] || "📦" %></span>
          <span class="home__collection-label"><%= collection_labels[collection.name] || collection.name %></span>
          <span class="home__collection-count"><%= collection.games.count %></span>
        <% end %>
      <% end %>
    </div>
  </section>
  <% end %>

<!-- Game suggestion -->
  <% if user_signed_in? && @collections.any? %>
    <section class="home__section">
      <div class="home__section-header">
        <div class="suggestions__home">
          <div class="home__section-header">
            <h2 class="home__section-title">Suggestions</h2>
          </div>
          <div class="games-grid">
            <% @suggestion_games.each do |game| %>
              <%= render "games/game_card", game: game, show_add_btn: true %>
            <% end %>
          </div>
        </div>
      </div>
    </section>
  <% end %>
</div>
