<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow-sm">
        <div class="card-body text-center p-4">
          <% if @user.profile_photo_url.present? %>
            <%= image_tag @user.profile_photo_url, class: "avatar avatar-xl mb-3", alt: @user.username %>
          <% else %>
            <div class="avatar avatar-xl mb-3 bg-secondary rounded-circle d-flex align-items-center justify-content-center mx-auto" style="width: 80px; height: 80px;">
            <i class="fas fa-user fa-2x text-white"></i>
          </div>
          <% end %>

          <h3 class="card-title mb-1"><%= @user.username.presence || @user.email %></h3>
          <p class="text-muted mb-2"><%= @user.email %></p>
          <% if @user.city.present? %>
            <p class="mb-3"><i class="fas fa-map-marker-alt me-1"></i><%= @user.city %></p>
          <% end %>

          <% if current_user == @user %>
            <%= link_to "Edit profile", edit_user_path(@user), class: "btn btn-outline-dark" %>
            <%= link_to "My collections", collections_path, class: "btn btn-dark ms-2" %>
            <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "btn btn-outline-danger ms-2" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
