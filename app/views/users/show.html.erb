<div class="profile-page">
  <div class="profile-header">
    <% if @user.profile_photo_url.present? %>
      <%= image_tag @user.profile_photo_url, class: "profile-avatar", alt: @user.username %>
    <% else %>
      <div class="profile-avatar-placeholder">
        <i class="fas fa-user fa-2x text-white"></i>
      </div>
    <% end %>
    <h2 class="profile-name"><%= @user.username.presence || @user.email %></h2>
    <p class="profile-email"><%= @user.email %></p>
    <% if @user.city.present? %>
      <p class="profile-city"><i class="fas fa-map-marker-alt me-1"></i><%= @user.city %></p>
    <% end %>
  </div>

  <% if current_user == @user %>
    <div class="profile-actions">
      <%= link_to "My collections", collections_path, class: "btn-profile-primary" %>
      <%= link_to "Edit profile", edit_user_path(@user), class: "btn-profile-secondary" %>
      <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "btn-profile-logout" %>
    </div>
  <% end %>
</div>
