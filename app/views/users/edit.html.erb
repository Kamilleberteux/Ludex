<div class="edit-profile-page">
  <div class="edit-profile-header">
    <a href="<%= user_path(@user) %>" class="back-btn">
      <i class="fas fa-arrow-left"></i>
    </a>
    <h2>Modifier le profil</h2>
  </div>

  <%= form_with model: @user, url: user_path(@user), method: :patch, multipart: true do |f| %>
    <% if @user.errors.any? %>
      <div class="alert alert-danger mb-3">
        <ul class="mb-0">
          <% @user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="edit-profile-photo" data-controller="photo-preview">
      <% if @user.profile_photo_url.present? %>
        <img src="<%= @user.profile_photo_url %>" class="current-photo" data-photo-preview-target="preview" />
      <% else %>
        <div class="photo-placeholder" data-photo-preview-target="placeholder">
          <i class="fas fa-user fa-2x text-white"></i>
        </div>
        <img class="current-photo d-none" data-photo-preview-target="preview" />
      <% end %>
      <%= f.file_field :profile_photo, class: "d-none", accept: "image/*", id: "photo-upload", data: { photo_preview_target: "input", action: "change->photo-preview#preview" } %>
      <label for="photo-upload" class="change-photo-btn">Changer la photo</label>
      <% if @user.profile_photo_url.present? %>
        <%= link_to "Supprimer la photo", remove_photo_user_path(@user), data: { turbo_method: :delete }, class: "btn-delete-photo" %>
      <% end %>
    </div>

    <div class="edit-profile-fields">
      <div class="field-group">
        <%= f.label :username, "Nom d'utilisateur", class: "field-label" %>
        <%= f.text_field :username, class: "field-input", placeholder: "Votre pseudo" %>
      </div>

      <div class="field-group">
        <%= f.label :email, "Email", class: "field-label" %>
        <%= f.email_field :email, class: "field-input" %>
      </div>

      <div class="field-group" data-controller="city-autocomplete">
        <%= f.label :city, "Ville", class: "field-label" %>
        <%= f.text_field :city, class: "field-input", placeholder: "Votre ville",
          data: { city_autocomplete_target: "input" },
          autocomplete: "off" %>
        <ul data-city-autocomplete-target="suggestions" class="autocomplete-list"></ul>
      </div>
    </div>

    <div class="edit-profile-actions">
      <%= f.submit "Enregistrer", class: "btn-profile-primary" %>
      <%= link_to "Annuler", user_path(@user), class: "btn-profile-secondary" %>
    </div>
  <% end %>
</div>
