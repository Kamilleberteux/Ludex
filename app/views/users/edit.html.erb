<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <h2 class="mb-4">Edit profile</h2>
      <%= form_with model: @user, url: user_path(@user), method: :patch, multipart: true do |f| %>
        <% if @user.errors.any? %>
          <div class="alert alert-danger">
            <ul class="mb-0">
              <% @user.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="mb-3">
          <%= f.label :username, class: "form-label" %>
          <%= f.text_field :username, class: "form-control", placeholder: "Your username" %>
        </div>

        <div class="mb-3">
          <%= f.label :email, class: "form-label" %>
          <%= f.email_field :email, class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= f.label :city, class: "form-label" %>
          <%= f.text_field :city, class: "form-control", placeholder: "Your city" %>
        </div>

        <div class="mb-3">
          <%= f.label :profile_photo, "Profile photo", class: "form-label" %>
          <% if @user.profile_photo_url.present? %>
            <%= image_tag @user.profile_photo_url, class: "d-block mb-2 rounded", style: "width: 80px; height: 80px; object-fit: cover;" %>
          <% end %>
          <%= f.file_field :profile_photo, class: "form-control", accept: "image/*" %>
        </div>

        <div class="d-flex gap-2">
          <%= f.submit "Save changes", class: "btn btn-dark" %>
          <%= link_to "Cancel", user_path(@user), class: "btn btn-outline-secondary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

