<div class="game-show-container">
  <%# 1. Zone Image (Carrousel) %>
  <div class="game-hero">
  </div>
 <%# On ajoute data-controller="swiper" sur l'élément parent %>
<div class="swiper game-carousel" data-controller="swiper">
  <div class="swiper-wrapper">
    <% @game.photo_urls.each do |url| %>
      <div class="swiper-slide">
        <%= image_tag url, class: "carousel-img" %>
      </div>
    <% end %>
      <%# Le nom du jeu incrusté %>
      <div class="game-show-overlay">
        <%# La "bulle" qui contiendra le titre %>
        <div class="game-bubble-title">
          <span><%= @game.name %></span>
        </div>
      </div>

  <div class="swiper-pagination"></div>
</div>


</div>
  <%# Pagination points %>


  <div class="game-content">
    <%# 2. Tag catégorie %>
    <div class="category-tag"><i class="fa-solid fa-puzzle-piece"></i> <%= @game.theme %> </div>
    <%# 3. Grille d'infos (Les 4 petits carrés) %>
    <div class="info-grid">
      <div class="info-card">
        <i class="icon-users"></i>
        <strong><%= "#{@game.nb_players_min} à #{@game.nb_players_max}" %></strong><br><span>JOUEURS</span>
      </div>
      <div class="info-card">
        <i class="icon-clock"></i>
        <strong><%= @game.play_time_minutes %></strong><br><span>DURÉE</span>
      </div>
      <div class="info-card">
        <i class="icon-sword"></i>
        <strong>
            <% if @game.is_cooperative? %>
              Cooperatif
            <% else %>
              Compétitif
            <% end %>
          </strong>
  <br>
    <span>MODE</span>
      </div>
      <div class="info-card">
        <i class="icon-cap"></i>
        <strong><%= @game.level %></strong><br><span>NIVEAU</span>
      </div>
    </div>

    <%# 4. Description %>
    <h2>Description</h2>
      <div data-controller="read-more">
       <%# La classe "line-clamp" limite le texte à 3 lignes (besoin de Tailwind ou CSS) %>
       <div data-read-more-target="content" class="description-text">
    <%= @game.description %>
  </div>

  <button data-action="click->read-more#toggle" data-read-more-target="button" class="read-more-btn">
    Lire la suite...
  </button>
  </div>

    <%# 5. Section Achat %>
    <h2>Prix indicatif</h2>
    <div class="price"><%= @game.price %> €</div>

    <h2>Jeux similaires</h2>
    <div class="games-grid">
        <% @similar_games.each do |game| %>
          <%= render "games/game_card", game: game, show_add_btn: true %>
        <% end %>
    </div>
  </div>

  <div class="video-container">
  <h3>Découvrez le jeu en vidéo</h3>
  <div class="video-wrapper">
    <iframe
      src="https://www.youtube.com/embed/ID_DE_LA_VIDEO"
      title="YouTube video player"
      frameborder="0"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      allowfullscreen>
    </iframe>
  </div>
</div>
</div>
