<div class="game-show-container">
  <%# Conteneur parent pour fixer le bouton par dessus le carrousel %>
  <div class="game-carousel-container">

    <%# 1. Le bouton dropdown (fixe) %>
  <div class="dropdown game-add-dropdown" data-controller="dropdown">
  <button class="game-card__add-btn1" type="button" data-action="click->dropdown#toggle" data-dropdown-target="addBtn">+</button>

  <div class="dropdown__menu" data-dropdown-target="menu">
    <p class="dropdown__label">Ajouter à...</p>

    <%# --- LA BOUCLE EST ESSENTIELLE ICI --- %>
    <% current_user.collections.each do |collection| %>

      <%= button_to add_game_collection_path(collection, game_id: @game.id),
                    method: :post,
                    class: "dropdown__item",
                    form: { data: { action: "submit->dropdown#handleAdd" } } do %>
        <%= collection.name %>
      <% end %>

    <% end %>
  </div>
</div>
      </div>
    </div>

    <%# 2. Le carrousel Swiper %>
    <div class="swiper game-carousel" data-controller="swiper">
      <div class="swiper-wrapper">
        <% @game.photo_urls.each do |url| %>
          <div class="swiper-slide">
            <%= image_tag url, class: "carousel-img" %>
          </div>
        <% end %>
      </div>
      <div class="swiper-pagination"></div>
    </div>

  <div class="game-content">
  <h1><%= @game.name %></h1>
<%# Theme %>
<div class="etiquette">
   <% if @game.theme.present? %>
  <div class="category-tag">
    <i class="fa-solid fa-puzzle-piece"></i>
    <p><%= @game.theme.capitalize %></p>
  </div>
<% end %>

    <%# Friends collection owners %>
    <!-- ---------------------------
    Button to friends owners
    ---------------------------- -->
    <% if @owners.count > 0 %>
    <div class="friends-section" data-controller="dropdown" data-action="click@window->dropdown#close">
      <div class="friends-badge" data-action="click->dropdown#toggle" data-dropdown-target="addBtn">
        <span class="friends-badge__text">Tes amis ont ce jeu</span>
        <div class="friends-badge__avatars">
          <% @owners.first(3).each do |owner| %>
            <%= image_tag owner.profile_photo_url || 'default-user.png', class: "friends-badge__avatar" %>
          <% end %>
          <% if @owners.count > 3 %>
            <span class="friends-badge__more">+<%= @owners.count - 3 %></span>
          <% end %>
        </div>
      </div>
      <div class="dropdown__menu" data-dropdown-target="menu">
        <p class="dropdown__label">Mes amis</p>
        <% @owners.each do |owner| %>
          <div class="friends-dropdown-item">
            <%= image_tag owner.profile_photo_url || 'default-user.png', class: "friends__result-avatar" %>
            <%= owner.username %>
          </div>
        <% end %>
      </div>
    </div>
        <% end %>
    </div>


    <%# 3. Grille d'infos (Les 4 petits carrés) %>
    <div class="info-grid">
      <div class="info-card">
        👥<br>
        <i class="icon-users"></i>
        <span class="text-bold"><%= "#{@game.nb_players_min} à #{@game.nb_players_max}" %></span><br><span>JOUEURS</span>
      </div>
      <div class="info-card">
        ⏳<br>
        <i class="icon-clock"></i>
        <span class="text-bold"><%= @game.play_time_minutes %></span><br><span>DURÉE</span>
      </div>
      <div class="info-card">
        <i class="icon-sword"></i>
        <span class="text-bold">
        <% if @game.is_cooperative? %>
         🤝 <br>
         Cooperatif
        <% else %>
         ⚔️ <br>
         Compétitif
        <% end %></span>

        <br>
        <span>MODE</span>
      </div>
      <div class="info-card">
        <i class="icon-cap"></i>
        <span class="text-bold">
          <% if @game.level == "Enfant" %>
            🎈 <br>Enfant
          <% elsif @game.level == "Familial" %>
            👨‍👩‍👧‍👦 <br>Familial
          <% elsif @game.level == "Initié" %>
            🧠 <br>Initié
        <% elsif @game.level == "Expert" %>
            💀 <br>Expert
        <% end %></span>
        <br><span>NIVEAU</span>
      </div>
    </div>

    <%# 4. Description %>
    <h2>Description</h2>
    <div data-controller="read-more">
      <%# La classe "line-clamp" limite le texte à 3 lignes (besoin de Tailwind ou CSS) %>
      <div data-read-more-target="content" class="description-text">
        <%= @game.description %>
      </div>

      <button data-action="click->read-more#toggle" data-read-more-target="button" class="read-more-btn">
        Lire la suite...
      </button>
    </div>

    <%# 5. Section Achat %>
    <h2>Où l'acheter</h2>
  <div class="price-container">
    <div class="price-info">
      <span class="price-label">PRIX INDICATIF</span>
      <span class="price-value"><%= number_with_precision(@game.price, precision: 2) %> €</span>
    </div>
  <% if @game.has_correct_url %>
    <%= link_to "https://shop.loufoque.fr/products/#{@game.name.parameterize}", target: "_blank", class: "shop-button" do %>
      <i class="icon-shop"></i> Voir la boutique
     <% end %>
  <% else %>
    <%= link_to "https://shop.loufoque.fr/search?q=#{CGI.escape(@game.name)}", target: "_blank", class: "shop-button" do %>
      <i class="icon-shop"></i> Voir la boutique
    <% end %>
  <% end %>

  </div>

    <% if @game.video_url.present? %>
      <h2>Découvrez les règles du jeu en vidéo</h2>
      <div class="video-container">
        <div class="video-wrapper">
          <iframe
        src="<%= @game.video_url %>"
        frameborder="0"
        allowfullscreen>
          </iframe>
        </div>
      </div>
    <% end %>

    <h2>Jeux similaires</h2>
    <div class="games-grid">
      <% @similar_games.each do |game| %>
        <%= render "games/game_card", game: game, show_add_btn: true %>
      <% end %>
    </div>
  </div>
