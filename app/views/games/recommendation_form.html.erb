<%= form_with url: recommendation_games_path, method: :post,
  class: "reco-form",
  data: { controller: "recommendation", turbo_cache: false } do %>

    <%# Hidden inputs pour stocker les réponses %>
    <input type="hidden" name="intent" value="">
    <input type="hidden" name="nb_players" value="">
    <input type="hidden" name="play_time" value="">
    <input type="hidden" name="audience" value="">
    <input type="hidden" name="theme" value="">
    <input type="hidden" name="interaction" value="">
    <input type="hidden" name="budget" value="">

    <%# Étape 1 : Intention %>
    <div data-recommendation-target="step" class="reco-step">
      <div class="reco-step__top">
        <div class="reco-step__progress-track">
          <div class="reco-step__progress-fill" style="width: 14%"></div>
        </div>
        <p class="reco-step__counter">1 / 6</p>
        <h2 class="reco-step__question">Je souhaite...</h2>
      </div>
      <div class="reco-step__bottom">
        <button type="button" class="reco-btn"
                data-action="click->recommendation#answer"
                data-name="intent" data-value="similar">
          <span class="reco-btn__icon">🔍</span>
          Trouver un jeu similaire à un autre
        </button>
        <button type="button" class="reco-btn"
                data-action="click->recommendation#answer"
                data-name="intent" data-value="personalized">
          <span class="reco-btn__icon">✨</span>
          Avoir une recommandation personnalisée
        </button>
      </div>
    </div>

    <%# Étape 2 : Nombre de joueurs %>
    <div data-recommendation-target="step" class="reco-step">
      <div class="reco-step__top">
        <button type="button" class="reco-step__back" data-action="click->recommendation#back">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
          </svg>
        </button>
        <div class="reco-step__progress-track">
          <div class="reco-step__progress-fill" style="width: 28%"></div>
        </div>
        <p class="reco-step__counter">2 / 6</p>
        <h2 class="reco-step__question">Vous serez combien à jouer ?</h2>
      </div>
      <div class="reco-step__bottom">
        <button type="button" class="reco-btn"
                data-action="click->recommendation#answer"
                data-name="nb_players" data-value="2">
          <span class="reco-btn__icon">👥</span> 2 joueurs
        </button>
        <button type="button" class="reco-btn"
                data-action="click->recommendation#answer"
                data-name="nb_players" data-value="4">
          <span class="reco-btn__icon">👥</span> 3–4 joueurs
        </button>
        <button type="button" class="reco-btn"
                data-action="click->recommendation#answer"
                data-name="nb_players" data-value="6">
          <span class="reco-btn__icon">👨‍👩‍👧‍👦</span> 5–6 joueurs
        </button>
        <button type="button" class="reco-btn"
                data-action="click->recommendation#answer"
                data-name="nb_players" data-value="7">
          <span class="reco-btn__icon">🎉</span> 7 joueurs ou +
        </button>
      </div>
    </div>

    <%# Étape 3 : Temps de jeu %>
    <div data-recommendation-target="step" class="reco-step">
      <div class="reco-step__top">
        <button type="button" class="reco-step__back" data-action="click->recommendation#back">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
          </svg>
        </button>
        <div class="reco-step__progress-track">
          <div class="reco-step__progress-fill" style="width: 43%"></div>
        </div>
        <p class="reco-step__counter">3 / 6</p>
        <h2 class="reco-step__question">Combien de temps voulez-vous jouer ?</h2>
      </div>
      <div class="reco-step__bottom">
        <button type="button" class="reco-btn"
                data-action="click->recommendation#answer"
                data-name="play_time" data-value="30">
          <span class="reco-btn__icon">⚡</span> 30 min ou moins
        </button>
        <button type="button" class="reco-btn"
                data-action="click->recommendation#answer"
                data-name="play_time" data-value="60">
          <span class="reco-btn__icon">⏱️</span> Environ 1h
        </button>
        <button type="button" class="reco-btn"
                data-action="click->recommendation#answer"
                data-name="play_time" data-value="120">
          <span class="reco-btn__icon">🕐</span> Environ 2h
        </button>
        <button type="button" class="reco-btn"
                data-action="click->recommendation#answer"
                data-name="play_time" data-value="180">
          <span class="reco-btn__icon">🌙</span> 2h ou plus
        </button>
      </div>
    </div>

    <%# Étape 4 : Public %>
    <div data-recommendation-target="step" class="reco-step">
      <div class="reco-step__top">
        <button type="button" class="reco-step__back" data-action="click->recommendation#back">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
          </svg>
        </button>
        <div class="reco-step__progress-track">
          <div class="reco-step__progress-fill" style="width: 57%"></div>
        </div>
        <p class="reco-step__counter">4 / 6</p>
        <h2 class="reco-step__question">Avec qui allez-vous jouer ?</h2>
      </div>
      <div class="reco-step__bottom">
        <button type="button" class="reco-btn"
                data-action="click->recommendation#answer"
                data-name="audience" data-value="children">
          <span class="reco-btn__icon">🧒</span> Des enfants
        </button>
        <button type="button" class="reco-btn"
                data-action="click->recommendation#answer"
                data-name="audience" data-value="all">
          <span class="reco-btn__icon">🌍</span> Tout le monde
        </button>
        <button type="button" class="reco-btn"
                data-action="click->recommendation#answer"
                data-name="audience" data-value="casual">
          <span class="reco-btn__icon">😊</span> Des joueurs occasionnels
        </button>
        <button type="button" class="reco-btn"
                data-action="click->recommendation#answer"
                data-name="audience" data-value="expert">
          <span class="reco-btn__icon">🧠</span> Des gros joueurs
        </button>
      </div>
    </div>

    <%# Étape 5 : Interaction %>
    <div data-recommendation-target="step" class="reco-step">
      <div class="reco-step__top">
        <button type="button" class="reco-step__back" data-action="click->recommendation#back">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
          </svg>
        </button>
        <div class="reco-step__progress-track">
          <div class="reco-step__progress-fill" style="width: 85%"></div>
        </div>
        <p class="reco-step__counter">5 / 6</p>
        <h2 class="reco-step__question">Quel type d'interaction préférez-vous ?</h2>
      </div>
      <div class="reco-step__bottom">
        <button type="button" class="reco-btn"
                data-action="click->recommendation#answer"
                data-name="interaction" data-value="competitive">
          <span class="reco-btn__icon">⚔️</span> Compétitif
        </button>
        <button type="button" class="reco-btn"
                data-action="click->recommendation#answer"
                data-name="interaction" data-value="cooperative">
          <span class="reco-btn__icon">🤝</span> Coopératif
        </button>
        <button type="button" class="reco-btn"
                data-action="click->recommendation#answer"
                data-name="interaction" data-value="any">
          <span class="reco-btn__icon">😄</span> Peu m'importe
        </button>
      </div>
    </div>

    <%# Étape 6 : Budget %>
    <div data-recommendation-target="step" class="reco-step">
      <div class="reco-step__top">
        <button type="button" class="reco-step__back" data-action="click->recommendation#back">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
          </svg>
        </button>
        <div class="reco-step__progress-track">
          <div class="reco-step__progress-fill" style="width: 100%"></div>
        </div>
        <p class="reco-step__counter">6 / 6</p>
        <h2 class="reco-step__question">Quel est votre budget ?</h2>
      </div>
      <div class="reco-step__bottom">
        <button type="button" class="reco-btn"
                data-action="click->recommendation#answer"
                data-name="budget" data-value="20">
          <span class="reco-btn__icon">💰</span> Entre 10€ et 20€
        </button>
        <button type="button" class="reco-btn"
                data-action="click->recommendation#answer"
                data-name="budget" data-value="50">
          <span class="reco-btn__icon">💳</span> Entre 30€ et 50€
        </button>
        <button type="button" class="reco-btn"
                data-action="click->recommendation#answer"
                data-name="budget" data-value="100">
          <span class="reco-btn__icon">💎</span> Entre 60€ et 100€
        </button>
        <button type="button" class="reco-btn"
                data-action="click->recommendation#answer"
                data-name="budget" data-value="any">
          <span class="reco-btn__icon">🤑</span> Plus de 100€
        </button>
      </div>
    </div>

<% end %>
